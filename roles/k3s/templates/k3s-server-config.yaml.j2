# K3s Server Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
---
write-kubeconfig-mode: "{{ k3s_kubeconfig_mode }}"
cluster-cidr: "{{ k3s_cluster_cidr }}"
service-cidr: "{{ k3s_service_cidr }}"
cluster-dns: "{{ k3s_cluster_dns }}"
flannel-backend: "{{ k3s_flannel_backend }}"
data-dir: "{{ k3s_data_dir }}"

{% if k3s_tls_san | length > 0 %}
tls-san:
{% for san in k3s_tls_san %}
  - "{{ san }}"
{% endfor %}
{% endif %}

{% if k3s_cluster_init %}
cluster-init: true
{% endif %}

disable:
{% if k3s_disable_traefik %}
  - traefik
{% endif %}
{% if k3s_disable_servicelb %}
  - servicelb
{% endif %}
{% if k3s_disable_local_storage %}
  - local-storage
{% endif %}
