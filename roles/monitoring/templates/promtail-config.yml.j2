# =============================================================================
# Promtail Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

server:
  http_listen_port: {{ promtail_port }}
  grpc_listen_port: 0

positions:
  filename: {{ promtail_positions_dir }}/positions.yaml

clients:
  - url: {{ promtail_loki_url }}

scrape_configs:
{% for job in promtail_scrape_configs %}
  - job_name: {{ job.job_name }}
    static_configs:
      - targets:
          - localhost
        labels:
{% for key, value in job.labels.items() %}
          {{ key }}: "{{ value }}"
{% endfor %}
          __path__: {{ job.path }}
{% endfor %}
