# Restic environment - managed by Ansible, DO NOT EDIT MANUALLY
{% if backup_backend == 's3' %}
RESTIC_REPOSITORY={{ backup_s3_bucket }}
AWS_ACCESS_KEY_ID={{ backup_s3_access_key }}
AWS_SECRET_ACCESS_KEY={{ backup_s3_secret_key }}
AWS_DEFAULT_REGION={{ backup_s3_region }}
{% elif backup_backend == 'gs' %}
RESTIC_REPOSITORY={{ backup_gcs_bucket }}
GOOGLE_APPLICATION_CREDENTIALS={{ backup_gcs_credentials }}
{% endif %}
RESTIC_PASSWORD={{ backup_restic_password }}
RESTIC_CACHE_DIR={{ restic_cache_dir }}
